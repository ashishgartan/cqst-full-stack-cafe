<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order History | FullStack Café</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes slideIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .order-anim {
        animation: slideIn 0.4s ease forwards;
      }

      /* Hide scrollbar for cleaner look */
      .no-scrollbar::-webkit-scrollbar {
        display: none;
      }
    </style>
  </head>
  <body class="bg-gray-50 font-sans antialiased text-gray-900">
    <%- include('../partials/header') %>

    <main class="min-h-screen py-8 md:py-12 px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto">
        <div
          class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8 md:mb-10"
        >
          <div>
            <h1
              class="text-3xl md:text-4xl font-black tracking-tight text-gray-900"
            >
              Order History
            </h1>
            <p class="mt-1 text-gray-500 font-medium text-sm md:text-base">
              Track your delicious moments.
            </p>
          </div>
          <a
            href="/products"
            class="inline-flex items-center justify-center bg-red-700 text-white px-6 py-4 rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-black transition-all shadow-xl shadow-red-100 active:scale-95"
          >
            <span class="mr-2">＋</span> New Order
          </a>
        </div>

        <div
          class="hidden md:block bg-white rounded-[2.5rem] shadow-sm border border-gray-100 overflow-hidden min-h-[400px]"
        >
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead class="bg-gray-50/50 border-b border-gray-100">
                <tr>
                  <th
                    class="px-8 py-5 text-[10px] font-black uppercase text-gray-400 tracking-widest"
                  >
                    Order ID
                  </th>
                  <th
                    class="px-8 py-5 text-[10px] font-black uppercase text-gray-400 tracking-widest"
                  >
                    Date
                  </th>
                  <th
                    class="px-8 py-5 text-[10px] font-black uppercase text-gray-400 tracking-widest"
                  >
                    Items
                  </th>
                  <th
                    class="px-8 py-5 text-[10px] font-black uppercase text-gray-400 tracking-widest"
                  >
                    Total
                  </th>
                  <th
                    class="px-8 py-5 text-[10px] font-black uppercase text-gray-400 tracking-widest text-center"
                  >
                    Status
                  </th>
                </tr>
              </thead>
              <tbody
                id="order-tbody-desktop"
                class="divide-y divide-gray-50"
              ></tbody>
            </table>
          </div>
        </div>

        <div id="order-list-mobile" class="md:hidden space-y-4">
          <div
            class="py-20 text-center animate-pulse font-black text-gray-300 text-xs uppercase tracking-widest"
          >
            Syncing Kitchen...
          </div>
        </div>

        <div
          id="pagination-footer"
          class="mt-8 px-4 flex flex-col md:flex-row items-center justify-between gap-6 hidden"
        >
          <div
            id="page-info"
            class="text-[10px] font-black text-gray-400 uppercase tracking-widest"
          ></div>
          <nav
            id="pagination-nav"
            class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-2"
          ></nav>
        </div>
      </div>
    </main>

    <div id="cancel-modal" class="fixed inset-0 z-[150] hidden">
      <div
        class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm"
        onclick="closeCancelModal()"
      ></div>
      <div
        class="relative flex items-end md:items-center justify-center min-h-screen"
      >
        <div
          class="bg-white w-full max-w-md rounded-t-[2.5rem] md:rounded-[2.5rem] shadow-2xl overflow-hidden order-anim"
        >
          <div class="p-8">
            <div class="flex justify-center md:justify-start mb-6">
              <div
                class="bg-rose-50 w-14 h-14 rounded-2xl flex items-center justify-center text-rose-600"
              >
                <svg
                  class="w-7 h-7"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2.5"
                    d="M6 18L18 6M6 6l12 12"
                  />
                </svg>
              </div>
            </div>
            <h3
              class="text-2xl font-black text-gray-900 mb-2 text-center md:text-left"
            >
              Cancel Order?
            </h3>
            <p class="text-gray-500 font-medium mb-6 text-center md:text-left">
              Please select a reason for cancellation:
            </p>

            <div class="space-y-3 mb-8" id="reason-options">
              <button
                onclick="submitCancel('Change of mind')"
                class="w-full text-center md:text-left px-6 py-4 rounded-2xl border-2 border-gray-50 font-black text-xs uppercase tracking-widest text-gray-600 hover:border-rose-200 hover:bg-rose-50 transition-all"
              >
                Change of mind
              </button>
              <button
                onclick="submitCancel('Ordered by mistake')"
                class="w-full text-center md:text-left px-6 py-4 rounded-2xl border-2 border-gray-50 font-black text-xs uppercase tracking-widest text-gray-600 hover:border-rose-200 hover:bg-rose-50 transition-all"
              >
                Ordered by mistake
              </button>
              <textarea
                id="manual-reason"
                placeholder="Type other reason..."
                class="w-full p-4 rounded-2xl border-2 border-gray-50 font-bold text-sm focus:border-rose-500 outline-none transition-all"
                rows="2"
              ></textarea>
            </div>

            <div class="flex flex-col-reverse md:flex-row gap-3">
              <button
                onclick="closeCancelModal()"
                class="flex-1 py-4 font-black text-[10px] uppercase tracking-widest text-gray-400"
              >
                Nevermind
              </button>
              <button
                onclick="submitManualCancel()"
                class="flex-1 py-4 bg-gray-900 text-white rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-rose-600 shadow-lg transition-all"
              >
                Confirm Cancel
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
      const state = { page: 1, currentOrderId: null };

      async function fetchOrders() {
        const desktopTbody = document.getElementById("order-tbody-desktop");
        const mobileList = document.getElementById("order-list-mobile");
        const footer = document.getElementById("pagination-footer");

        const loader = `<div class="py-20 text-center animate-pulse font-black text-gray-300 text-xs uppercase tracking-widest">Syncing Kitchen...</div>`;
        desktopTbody.innerHTML = `<tr><td colspan="5">${loader}</td></tr>`;
        mobileList.innerHTML = loader;

        try {
          const res = await fetch(`/api/orders?page=${state.page}`);
          const data = await res.json();

          if (!data.orders || data.orders.length === 0) {
            const empty = `<div class="py-32 text-center text-gray-400 font-black uppercase text-xs tracking-widest">No orders yet!</div>`;
            desktopTbody.innerHTML = `<tr><td colspan="5">${empty}</td></tr>`;
            mobileList.innerHTML = empty;
            footer.classList.add("hidden");
            return;
          }

          renderDesktop(data.orders);
          renderMobile(data.orders);
          renderPagination(data.totalPages, data.currentPage);
          footer.classList.remove("hidden");
        } catch (err) {
          showToast("Failed to fetch orders", "error");
        }
      }

      function getStatusStyles(status) {
        const map = {
          Pending: "bg-amber-50 text-amber-700 border-amber-100",
          Preparing: "bg-blue-50 text-blue-700 border-blue-100",
          Ready: "bg-purple-50 text-purple-700 border-purple-100",
          Delivered: "bg-emerald-50 text-emerald-700 border-emerald-100",
          Cancelled: "bg-rose-50 text-rose-700 border-rose-100 opacity-60",
        };
        return map[status] || "bg-gray-50 text-gray-600";
      }

      function renderDesktop(orders) {
        document.getElementById("order-tbody-desktop").innerHTML = orders
          .map(
            (order, i) => `
          <tr class="order-anim hover:bg-gray-50/50 transition-colors" style="animation-delay: ${
            i * 50
          }ms">
            <td class="px-8 py-6"><span class="text-[10px] font-black text-gray-400 bg-gray-100 px-2 py-1 rounded-lg">#${order._id.slice(
              -6
            )}</span></td>
            <td class="px-8 py-6 text-sm font-bold text-gray-700">${
              order.displayDate
            }</td>
            <td class="px-8 py-6">
              <div class="max-w-[200px] truncate font-bold text-xs text-gray-500">
                ${order.items
                  .map((it) => `${it.quantity}x ${it.name}`)
                  .join(", ")}
              </div>
            </td>
            <td class="px-8 py-6 text-lg font-black text-gray-900">₹${
              order.totalAmount
            }</td>
            <td class="px-8 py-6">
                <div class="flex flex-col items-center gap-1">
                    <span class="px-3 py-1 rounded-xl text-[9px] font-black uppercase tracking-widest border ${getStatusStyles(
                      order.status
                    )}">${order.status}</span>
                    ${
                      order.status === "Pending"
                        ? `<button onclick="openCancelModal('${order._id}')" class="text-[9px] font-black text-rose-500 uppercase hover:underline">Cancel</button>`
                        : ""
                    }
                </div>
            </td>
          </tr>`
          )
          .join("");
      }

      function renderMobile(orders) {
        document.getElementById("order-list-mobile").innerHTML = orders
          .map(
            (order, i) => `
          <div class="order-anim bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm" style="animation-delay: ${
            i * 50
          }ms">
            <div class="flex justify-between items-start mb-4">
              <div>
                <span class="text-[10px] font-black text-gray-400 uppercase tracking-widest">Order #${order._id.slice(
                  -6
                )}</span>
                <h3 class="text-sm font-black text-gray-900 mt-1">${
                  order.displayDate
                }</h3>
              </div>
              <span class="px-3 py-1 rounded-xl text-[9px] font-black uppercase tracking-widest border ${getStatusStyles(
                order.status
              )}">${order.status}</span>
            </div>
            
            <div class="space-y-2 mb-4 bg-gray-50 p-4 rounded-2xl">
              ${order.items
                .map(
                  (item) => `
                <div class="flex justify-between text-xs font-bold text-gray-600">
                  <span>${item.name} <span class="text-gray-400 ml-1">x${
                    item.quantity
                  }</span></span>
                  <span>₹${item.price * item.quantity}</span>
                </div>
              `
                )
                .join("")}
            </div>

            <div class="flex justify-between items-center">
              <span class="text-xl font-black text-gray-900">₹${
                order.totalAmount
              }</span>
              ${
                order.status === "Pending"
                  ? `
                <button onclick="openCancelModal('${order._id}')" class="bg-rose-50 text-rose-700 px-4 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest">
                  Cancel Order
                </button>
              `
                  : ""
              }
            </div>
          </div>`
          )
          .join("");
      }

      function openCancelModal(id) {
        state.currentOrderId = id;
        document.getElementById("cancel-modal").classList.remove("hidden");
      }

      function closeCancelModal() {
        document.getElementById("cancel-modal").classList.add("hidden");
      }

      async function submitCancel(reason) {
        document.getElementById("manual-reason").value = reason;
        await submitManualCancel();
      }

      async function submitManualCancel() {
        const reason = document.getElementById("manual-reason").value.trim();
        if (!reason) return showToast("Reason required", "error");

        try {
          const res = await fetch(
            `/api/orders/cancel/${state.currentOrderId}`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ reason }),
            }
          );
          if (res.ok) {
            closeCancelModal();
            fetchOrders();
            showToast("Order cancelled", "success");
          } else {
            showToast("Kitchen started, cannot cancel!", "error");
          }
        } catch (err) {
          showToast("Network error", "error");
        }
      }

      function renderPagination(total, current) {
        const nav = document.getElementById("pagination-nav");
        document.getElementById(
          "page-info"
        ).innerText = `Page ${current} of ${total}`;
        nav.innerHTML = "";
        for (let i = 1; i <= total; i++) {
          nav.innerHTML += `<button onclick="changePage(${i})" class="min-w-[40px] h-10 px-2 rounded-xl font-black text-xs transition-all ${
            i === current
              ? "bg-gray-900 text-white shadow-lg"
              : "bg-white border border-gray-100 text-gray-400"
          }">${i}</button>`;
        }
      }

      function changePage(p) {
        state.page = p;
        window.scrollTo({ top: 0, behavior: "smooth" });
        fetchOrders();
      }

      document.addEventListener("DOMContentLoaded", fetchOrders);
    </script>
  </body>
</html>
