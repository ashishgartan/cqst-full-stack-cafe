<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | FullStack Café</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-slide-up {
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .success-pulse {
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0% {
          box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.4);
        }
        70% {
          box-shadow: 0 0 0 10px rgba(22, 163, 74, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(22, 163, 74, 0);
        }
      }
    </style>
  </head>
  <body class="bg-gray-50 antialiased font-sans flex flex-col min-h-screen">
    <%- include('partials/header') %>

    <main
      class="flex-grow flex items-center justify-center py-10 md:py-20 px-4"
    >
      <div
        class="bg-white p-8 md:p-10 rounded-[2.5rem] shadow-xl shadow-gray-200/50 w-full max-w-[400px] border border-gray-100 animate-slide-up"
      >
        <div class="text-center mb-10">
          <div
            class="inline-flex items-center justify-center w-16 h-16 bg-red-50 rounded-2xl mb-4"
          >
            <span class="text-3xl">☕</span>
          </div>
          <h2
            class="text-3xl font-black text-gray-900 tracking-tighter mb-2 italic"
          >
            Welcome <span class="text-red-700">Back.</span>
          </h2>
          <p class="text-gray-500 font-medium text-sm">
            Fuel your code with premium campus meals.
          </p>
        </div>

        <form id="loginForm" class="space-y-5">
          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1"
              >Username</label
            >
            <input
              type="text"
              id="username"
              autocomplete="username"
              class="w-full px-5 py-4 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-700 outline-none transition bg-gray-50/50 font-bold text-gray-900"
              placeholder="FullStackDev"
              required
            />
          </div>

          <div class="relative">
            <div class="flex justify-between items-center mb-2 ml-1">
              <label
                class="text-[10px] font-black uppercase tracking-[0.2em] text-gray-400"
                >Password</label
              >
              <a
                href="#"
                class="text-[9px] font-black uppercase text-red-700 hover:underline"
                >Forgot?</a
              >
            </div>
            <input
              type="password"
              id="password"
              autocomplete="current-password"
              class="w-full px-5 py-4 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-700 outline-none transition bg-gray-50/50 font-bold text-gray-900"
              placeholder="••••••••"
              required
            />
            <button
              type="button"
              onclick="togglePass()"
              class="absolute right-4 bottom-4 text-gray-400 hover:text-red-700 transition p-1"
            >
              <svg
                id="eyeIcon"
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  id="eyePath"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                />
              </svg>
            </button>
          </div>

          <div
            id="errorMessage"
            class="hidden text-[11px] font-bold text-red-700 bg-red-50 p-4 rounded-2xl border border-red-100"
          ></div>

          <button
            type="submit"
            id="loginBtn"
            class="w-full bg-gray-900 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] hover:bg-red-700 shadow-xl shadow-gray-200 transition-all duration-300 transform active:scale-[0.97]"
          >
            Authorize Access
          </button>
        </form>

        <div class="mt-8 text-center">
          <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">
            New around here?
            <a
              href="/signup"
              class="text-red-700 ml-1 hover:underline underline-offset-4"
              >Create Account</a
            >
          </p>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script>
      /* Same logic as provided in your snippet */
      function urlBase64ToUint8Array(base64String) {
        const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
        const base64 = (base64String + padding)
          .replace(/-/g, "+")
          .replace(/_/g, "/");
        const rawData = window.atob(base64);
        const outputArray = new Uint8Array(rawData.length);
        for (let i = 0; i < rawData.length; ++i)
          outputArray[i] = rawData.charCodeAt(i);
        return outputArray;
      }

      function togglePass() {
        const pw = document.getElementById("password");
        const path = document.getElementById("eyePath");
        if (pw.type === "password") {
          pw.type = "text";
          path.setAttribute(
            "d",
            "M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18"
          );
        } else {
          pw.type = "password";
          path.setAttribute(
            "d",
            "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
          );
        }
      }

      async function getSubscription() {
        if ("serviceWorker" in navigator && "PushManager" in window) {
          try {
            const swReg = await navigator.serviceWorker.register("/sw.js");
            await navigator.serviceWorker.ready;
            const permission = await Notification.requestPermission();
            if (permission === "granted") {
              const publicVapidKey =
                "BKvHYRRtI59QFv3h6OXwnvIz3ObNKXzvkZIU1TJXSe6FBqgmahQ9ZHIZgL6FIUasuGzxDU2SZyp97g2RTAh7meU";
              return await swReg.pushManager.subscribe({
                userVisibleOnly: true,
                applicationServerKey: urlBase64ToUint8Array(publicVapidKey),
              });
            }
          } catch (err) {
            console.error("Push Error", err);
          }
        }
        return null;
      }

      document
        .getElementById("loginForm")
        .addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = document.getElementById("loginBtn");
          const errorBox = document.getElementById("errorMessage");

          btn.disabled = true;
          btn.innerHTML = `<span class="flex items-center justify-center gap-2">AUTHENTICATING...</span>`;

          try {
            const subscription = await getSubscription();
            const response = await fetch("/login", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                username: document.getElementById("username").value,
                password: document.getElementById("password").value,
                subscription: subscription,
              }),
            });

            const data = await response.json();
            if (data.success) {
              btn.classList.replace("bg-gray-900", "bg-green-600");
              btn.classList.add("success-pulse");
              btn.innerText = "ACCESS GRANTED";
              setTimeout(() => {
                window.location.href = data.redirectUrl || "/";
              }, 1000);
            } else {
              errorBox.innerText = data.message;
              errorBox.classList.remove("hidden");
              btn.disabled = false;
              btn.innerText = "AUTHORIZE ACCESS";
            }
          } catch (err) {
            errorBox.innerText = "CONNECTION ERROR.";
            errorBox.classList.remove("hidden");
            btn.disabled = false;
            btn.innerText = "AUTHORIZE ACCESS";
          }
        });
    </script>
  </body>
</html>
