<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icons/favicon.png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Menu | FullStack Café</title>
    <style>
      @layer utilities {
        .scrollbar-hide::-webkit-scrollbar {
          display: none;
        }
        .scrollbar-hide {
          -ms-overflow-style: none;
          scrollbar-width: none;
        }
      }
      @keyframes slideUpFade {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .product-card-anim {
        opacity: 0;
        animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      /* Smooth Modal Transition */
      #product-modal.flex {
        animation: fadeIn 0.3s ease;
      }
      #product-modal .modal-content {
        animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      @keyframes slideUp {
        from {
          transform: translateY(100%);
        }
        to {
          transform: translateY(0);
        }
      }
    </style>
  </head>
  <body class="bg-gray-50 font-sans text-gray-900 antialiased pb-20">
    <%- include('partials/header') %>

    <header
      class="relative bg-red-800 py-12 md:py-20 text-center text-white overflow-hidden shadow-inner"
    >
      <div
        class="absolute -top-20 -left-20 w-64 h-64 bg-red-600 rounded-full opacity-20 blur-3xl"
      ></div>
      <div class="relative z-10 px-6">
        <span
          class="inline-block bg-white/10 backdrop-blur-md px-4 py-1 rounded-full text-[9px] font-black uppercase tracking-[0.2em] mb-4 border border-white/10"
        >
          Campus Favorite
        </span>
        <h2 class="text-4xl md:text-7xl font-black tracking-tighter mb-2">
          Full Stack <span class="text-orange-400">Café</span>
        </h2>
        <p
          class="max-w-xs md:max-w-md mx-auto text-red-100 text-sm md:text-lg font-medium opacity-80"
        >
          Gourmet fuel for high-performance developers.
        </p>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 md:px-8 -mt-6 md:-mt-10 relative z-20">
      <div
        class="bg-white p-3 md:p-6 rounded-[2rem] shadow-xl shadow-gray-200/40 border border-gray-100 mb-8"
      >
        <div class="flex flex-col gap-4">
          <div
            class="flex gap-2 overflow-x-auto scrollbar-hide -mx-1 px-1 py-1"
          >
            <% ['all', 'Fast Food', 'Drinks', 'Desserts'].forEach(cat => { %>
            <button
              data-category="<%= cat %>"
              class="category-btn whitespace-nowrap px-6 py-3 rounded-2xl font-black text-[11px] uppercase tracking-widest transition-all active:scale-90 <%= cat === 'all' ? 'bg-red-700 text-white shadow-lg' : 'bg-gray-50 text-gray-500' %>"
            >
              <%= cat === 'all' ? 'All' : cat %>
            </button>
            <% }) %>
          </div>

          <div class="relative group">
            <span
              class="absolute inset-y-0 left-4 flex items-center text-gray-400"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2.5"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                />
              </svg>
            </span>
            <input
              type="text"
              id="search-input"
              placeholder="Hungry for something?"
              class="w-full pl-12 pr-4 py-4 bg-gray-50 border border-transparent rounded-[1.5rem] focus:bg-white focus:border-red-500/20 focus:ring-4 focus:ring-red-500/5 transition-all text-sm font-bold placeholder:text-gray-400"
            />
          </div>
        </div>
      </div>

      <div
        id="product-grid"
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 min-h-[400px]"
      ></div>

      <div
        id="pagination-controls"
        class="flex justify-center items-center gap-2 mt-12 mb-10 overflow-x-auto scrollbar-hide py-2"
      ></div>
    </main>

    <div
      id="product-modal"
      class="fixed inset-0 z-[100] hidden items-end md:items-center justify-center p-0 md:p-4 bg-gray-900/60 backdrop-blur-sm transition-all"
    >
      <div
        class="modal-content bg-white w-full max-w-3xl rounded-t-[2.5rem] md:rounded-[2.5rem] overflow-hidden shadow-2xl relative flex flex-col md:flex-row max-h-[90vh] md:max-h-none overflow-y-auto md:overflow-visible"
      >
        <button
          onclick="closeModal()"
          class="absolute top-4 right-4 z-20 bg-black/20 backdrop-blur-md text-white md:bg-white md:text-gray-900 rounded-full p-3 md:p-2 hover:bg-red-50 transition-colors"
        >
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M6 18L18 6M6 6l12 12"
              stroke-width="2.5"
              stroke-linecap="round"
            />
          </svg>
        </button>

        <div class="md:w-1/2 aspect-square md:aspect-auto">
          <img id="modal-img" src="" class="w-full h-full object-cover" />
        </div>

        <div class="p-8 md:p-10 md:w-1/2 flex flex-col">
          <span
            id="modal-category"
            class="text-[9px] font-black uppercase tracking-[0.2em] text-red-700 bg-red-50 px-3 py-1 rounded-lg w-fit"
          ></span>
          <h2
            id="modal-name"
            class="text-3xl md:text-4xl font-black text-gray-900 mt-4 leading-tight tracking-tighter"
          ></h2>
          <p
            id="modal-desc"
            class="text-gray-500 mt-4 leading-relaxed font-medium text-sm md:text-base"
          ></p>

          <div class="mt-8 md:mt-10 flex flex-col gap-4">
            <div
              class="flex items-center justify-between border-t border-gray-100 pt-6"
            >
              <span
                class="text-gray-400 font-bold uppercase text-[10px] tracking-widest"
                >Price per unit</span
              >
              <span
                id="modal-price"
                class="text-3xl font-black text-gray-900"
              ></span>
            </div>
            <button
              id="modal-add-btn"
              class="w-full bg-red-700 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] shadow-xl shadow-red-100 active:scale-95 transition-all"
            >
              Add to Bag
            </button>
          </div>
        </div>
      </div>
    </div>

    <%- include('partials/footer') %>

    <script>
      const state = { category: "all", page: 1, search: "" };

      async function fetchMenu() {
        const grid = document.getElementById("product-grid");
        grid.innerHTML = `
          <div class="col-span-full flex flex-col items-center justify-center py-20">
            <div class="w-10 h-10 border-4 border-gray-100 border-t-red-700 rounded-full animate-spin"></div>
            <p class="mt-4 text-gray-400 font-black uppercase tracking-widest text-[9px]">Fetching Dishes...</p>
          </div>`;

        try {
          const params = new URLSearchParams(state);
          const response = await fetch(`/api/products?${params}`);
          const data = await response.json();

          setTimeout(() => {
            renderProducts(data.products);
            renderPagination(data.totalPages, data.currentPage);
          }, 300);
        } catch (err) {
          grid.innerHTML = `<div class="col-span-full text-center py-20 text-red-500 font-bold">Failed to load menu.</div>`;
        }
      }

      function renderProducts(products) {
        const grid = document.getElementById("product-grid");
        if (!products.length) {
          grid.innerHTML = `
            <div class="col-span-full text-center py-20 bg-white rounded-[2rem] border-2 border-dashed border-gray-100">
              <h3 class="text-xl font-black text-gray-900 uppercase">No Match Found</h3>
              <p class="text-gray-400 font-medium text-sm mt-2">Try searching for something else.</p>
              <button onclick="resetAll()" class="mt-6 bg-gray-900 text-white px-8 py-3 rounded-xl font-bold text-xs uppercase tracking-widest">Reset Filters</button>
            </div>`;
          return;
        }

        grid.innerHTML = products
          .map(
            (p, i) => `
          <div class="product-card-anim group bg-white rounded-[2rem] shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all" style="animation-delay: ${
            i * 70
          }ms">
            <div class="relative aspect-[4/3] overflow-hidden cursor-pointer" onclick="openModal('${
              p._id
            }', '${p.name.replace(/'/g, "\\'")}', ${p.price}, '${
              p.image
            }', '${p.description.replace(/'/g, "\\'")}', '${p.category}')">
              <img src="/images/${
                p.image
              }" class="w-full h-full object-cover group-hover:scale-100 transition-transform duration-700" />
              <div class="absolute top-4 right-4 bg-white/95 backdrop-blur px-3 py-1 rounded-xl text-xs font-black text-red-700 shadow-sm">₹${
                p.price
              }</div>
            </div>
            <div class="p-6">
              <h3 class="font-black text-gray-800 mb-1 truncate">${p.name}</h3>
              <p class="text-gray-400 text-xs font-medium mb-6 line-clamp-1">${
                p.description
              }</p>
              <button onclick="addToCart('${p._id}', '${p.name.replace(
              /'/g,
              "\\'"
            )}', ${p.price}, '${
              p.image
            }')" class="w-full bg-gray-50 text-gray-900 py-4 rounded-xl font-black text-[10px] uppercase tracking-widest hover:bg-red-700 hover:text-white transition-all flex items-center justify-center gap-2">Add to Bag</button>
            </div>
          </div>
        `
          )
          .join("");
      }

      function renderPagination(total, active) {
        const container = document.getElementById("pagination-controls");
        if (total <= 1) {
          container.innerHTML = "";
          return;
        }

        container.innerHTML = Array.from({ length: total }, (_, i) => i + 1)
          .map(
            (i) => `
          <button onclick="changePage(${i})" class="min-w-[3rem] h-12 rounded-xl font-black transition-all border-2 ${
              i === active
                ? "bg-red-700 border-red-700 text-white shadow-lg"
                : "bg-white border-gray-100 text-gray-400"
            }">${i}</button>
        `
          )
          .join("");
      }

      function changePage(p) {
        state.page = p;
        const offset = window.innerWidth < 768 ? 200 : 400;
        window.scrollTo({ top: offset, behavior: "smooth" });
        fetchMenu();
      }

      function resetAll() {
        state.search = "";
        state.category = "all";
        document.getElementById("search-input").value = "";
        fetchMenu();
      }

      // Search and Filter Handlers
      let timer;
      document.getElementById("search-input").addEventListener("input", (e) => {
        clearTimeout(timer);
        timer = setTimeout(() => {
          state.search = e.target.value;
          state.page = 1;
          fetchMenu();
        }, 400);
      });

      document.querySelectorAll(".category-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
          document.querySelectorAll(".category-btn").forEach((b) => {
            b.classList.remove("bg-red-700", "text-white", "shadow-lg");
            b.classList.add("bg-gray-50", "text-gray-500");
          });
          btn.classList.replace("bg-gray-50", "bg-red-700");
          btn.classList.replace("text-gray-500", "text-white");
          btn.classList.add("shadow-lg");
          state.category = btn.dataset.category;
          state.page = 1;
          fetchMenu();
        });
      });

      function openModal(id, name, price, img, desc, category) {
        document.getElementById("modal-img").src = `/images/${img}`;
        document.getElementById("modal-name").innerText = name;
        document.getElementById("modal-desc").innerText = desc;
        document.getElementById("modal-price").innerText = `₹${price}`;
        document.getElementById("modal-category").innerText = category;
        document.getElementById("modal-add-btn").onclick = () => {
          addToCart(id, name, price, img);
          closeModal();
        };

        const m = document.getElementById("product-modal");
        m.classList.remove("hidden");
        m.classList.add("flex");
        document.body.style.overflow = "hidden"; // Prevent scroll
      }

      function closeModal() {
        const m = document.getElementById("product-modal");
        m.classList.add("hidden");
        m.classList.remove("flex");
        document.body.style.overflow = "";
      }

      function addToCart(id, name, price, img) {
        let cart = JSON.parse(localStorage.getItem("cart")) || [];
        const item = cart.find((i) => i.id === id);
        if (item) item.quantity += 1;
        else cart.push({ id, name, price, image: img, quantity: 1 });
        localStorage.setItem("cart", JSON.stringify(cart));
        if (window.updateCartBadge) updateCartBadge();
        if (window.showToast) showToast(`${name} added!`, "success");
      }

      document.addEventListener("DOMContentLoaded", fetchMenu);
    </script>
  </body>
</html>
