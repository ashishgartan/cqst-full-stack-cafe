<div
  id="toast-container"
  class="fixed top-20 md:top-24 left-1/2 -translate-x-1/2 z-[999] flex flex-col gap-3 w-[90%] max-w-sm"
></div>

<script>
  function updateCartBadge() {
    const cart = JSON.parse(localStorage.getItem("cart")) || [];
    const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
    const badge = document.getElementById("cart-count");
    if (badge) {
      badge.innerText = totalItems;
      badge.style.display = totalItems > 0 ? "block" : "none";
      if (totalItems > 0) {
        badge.classList.add("animate-bounce-short");
        setTimeout(() => badge.classList.remove("animate-bounce-short"), 300);
      }
    }
  }

  function showToast(message, type = "success") {
    const container = document.getElementById("toast-container");
    const toast = document.createElement("div");
    const isSuccess = type === "success";

    toast.className = `flex items-center gap-3 p-4 rounded-xl shadow-2xl border backdrop-blur-md transform transition-all duration-500 translate-y-[-20px] opacity-0 
      ${
        isSuccess
          ? "bg-white/90 border-emerald-100 text-emerald-900"
          : "bg-white/90 border-rose-100 text-rose-900"
      }`;

    toast.innerHTML = `
      <div class="${
        isSuccess ? "text-emerald-500" : "text-rose-500"
      } bg-white rounded-xl p-1 shadow-sm">
        ${
          isSuccess
            ? '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>'
            : '<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>'
        }
      </div>
      <p class="text-sm font-black tracking-tight">${message}</p>
    `;

    container.appendChild(toast);
    setTimeout(() => {
      toast.classList.replace("translate-y-[-20px]", "translate-y-0");
      toast.classList.replace("opacity-0", "opacity-100");
    }, 10);
    setTimeout(() => {
      toast.classList.add("opacity-0", "scale-90");
      setTimeout(() => toast.remove(), 500);
    }, 3000);
  }

  document.addEventListener("DOMContentLoaded", updateCartBadge);
</script>
