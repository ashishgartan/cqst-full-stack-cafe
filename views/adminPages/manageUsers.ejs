<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/icons/favicon.png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Full Stack Café</title>
  </head>
  <body class="bg-gray-100 min-h-screen font-sans antialiased">
    <%- include('../partials/header') %>
    <div class="p-4 md:p-8">
      <div class="max-w-7xl mx-auto">
        <h1 class="text-3xl font-black text-gray-800 mb-6 md:mb-8">
          User Directory
        </h1>

        <div
          class="bg-white rounded-[2rem] md:rounded-[2.5rem] shadow-sm border border-gray-100 overflow-hidden"
        >
          <div class="hidden md:block overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead
                class="bg-gray-50 text-[10px] font-black uppercase text-gray-400 tracking-widest border-b border-gray-100"
              >
                <tr>
                  <th class="px-8 py-6">Profile</th>
                  <th class="px-8 py-6">Contact Information</th>
                  <th class="px-8 py-6">Account Role</th>
                  <th class="px-8 py-6">Member Since</th>
                </tr>
              </thead>
              <tbody
                id="user-tbody-desktop"
                class="divide-y divide-gray-50"
              ></tbody>
            </table>
          </div>

          <div id="user-list-mobile" class="md:hidden divide-y divide-gray-100">
            <div class="p-10 text-center animate-pulse font-bold text-gray-300">
              Syncing Records...
            </div>
          </div>

          <div
            id="pagination-footer"
            class="px-6 py-6 bg-gray-50/50 border-t border-gray-100 flex flex-col md:flex-row items-center justify-between gap-6"
          >
            <p
              id="pagination-info"
              class="text-[10px] md:text-xs font-black text-gray-400 uppercase tracking-widest"
            ></p>
            <div
              id="pagination-controls"
              class="flex flex-wrap justify-center gap-2"
            ></div>
          </div>
        </div>
      </div>
    </div>

    <script>
      let state = { page: 1, limit: 10 };

      async function loadUsers() {
        const desktopTbody = document.getElementById("user-tbody-desktop");
        const mobileList = document.getElementById("user-list-mobile");

        const loader = `<div class="p-10 md:p-20 text-center animate-pulse font-bold text-gray-300">Syncing Records...</div>`;
        desktopTbody.innerHTML = `<tr><td colspan="4">${loader}</td></tr>`;
        mobileList.innerHTML = loader;

        try {
          const res = await fetch(
            `/api/admin/users?page=${state.page}&limit=${state.limit}`
          );
          const data = await res.json();

          renderUI(data.users);
          renderPagination(data.totalPages, data.currentPage);
        } catch (err) {
          const errorMsg = `<div class="p-10 md:p-20 text-center text-red-500 font-bold">Failed to connect to server.</div>`;
          desktopTbody.innerHTML = `<tr><td colspan="4">${errorMsg}</td></tr>`;
          mobileList.innerHTML = errorMsg;
        }
      }

      function renderUI(users) {
        const desktopTbody = document.getElementById("user-tbody-desktop");
        const mobileList = document.getElementById("user-list-mobile");

        if (!users || users.length === 0) {
          const emptyMsg = `<div class="p-20 text-center font-bold text-gray-400">No users found.</div>`;
          desktopTbody.innerHTML = `<tr><td colspan="4">${emptyMsg}</td></tr>`;
          mobileList.innerHTML = emptyMsg;
          return;
        }

        // --- Render Desktop View ---
        desktopTbody.innerHTML = users
          .map((u) => {
            const joinDate = formatDate(u.createdAt);
            return `
            <tr class="hover:bg-gray-50/50 transition-colors group">
              <td class="px-8 py-6">
                <div class="flex items-center gap-4">
                  <img src="/avatars/${
                    u.avatar || "/images/default-avatar.png"
                  }" 
                       class="w-12 h-12 rounded-full object-cover ring-2 ring-gray-100 group-hover:ring-red-100 transition-all"
                       onerror="this.src='https://ui-avatars.com/api/?name=${
                         u.username
                       }&background=fee2e2&color=b91c1c'">
                  <div>
                    <p class="font-black text-gray-900">${u.username}</p>
                    <p class="text-[10px] text-gray-400 font-bold uppercase tracking-tight">ID: ${u._id.slice(
                      -6
                    )}</p>
                  </div>
                </div>
              </td>
              <td class="px-8 py-6">
                <div class="flex flex-col gap-1 text-gray-600">
                  <div class="flex items-center text-sm font-bold">
                    <span class="mr-2 opacity-50">📧</span> ${u.email}
                  </div>
                  <div class="flex items-center text-xs font-medium text-gray-400">
                    <span class="mr-2 opacity-50">📞</span> ${
                      u.phone || "No phone added"
                    }
                  </div>
                </div>
              </td>
              <td class="px-8 py-6">
                <span class="inline-block px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest 
                    ${
                      u.role === "admin"
                        ? "bg-red-700 text-white shadow-lg shadow-red-100"
                        : "bg-gray-100 text-gray-600"
                    }">
                    ${u.role}
                </span>
              </td>
              <td class="px-8 py-6 whitespace-nowrap">
                <span class="text-sm font-black text-gray-400">${joinDate}</span>
              </td>
            </tr>`;
          })
          .join("");

        // --- Render Mobile View ---
        mobileList.innerHTML = users
          .map((u) => {
            const joinDate = formatDate(u.createdAt);
            return `
            <div class="p-6 flex flex-col gap-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <img src="/avatars/${
                    u.avatar || "/images/default-avatar.png"
                  }" 
                       class="w-14 h-14 rounded-full object-cover border-2 border-gray-100"
                       onerror="this.src='https://ui-avatars.com/api/?name=${
                         u.username
                       }&background=fee2e2&color=b91c1c'">
                  <div>
                    <p class="font-black text-gray-900 text-lg leading-tight">${
                      u.username
                    }</p>
                    <p class="text-[10px] text-gray-400 font-bold uppercase">ID: ${u._id.slice(
                      -6
                    )}</p>
                  </div>
                </div>
                <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest 
                    ${
                      u.role === "admin"
                        ? "bg-red-700 text-white"
                        : "bg-gray-100 text-gray-600"
                    }">
                    ${u.role}
                </span>
              </div>
              
              <div class="grid grid-cols-1 gap-2 bg-gray-50 p-4 rounded-2xl border border-gray-100">
                <div class="flex items-center text-xs font-bold text-gray-700 truncate">
                  <span class="w-6 opacity-50 text-sm">📧</span> ${u.email}
                </div>
                <div class="flex items-center text-xs font-bold text-gray-400">
                  <span class="w-6 opacity-50 text-sm">📞</span> ${
                    u.phone || "Not provided"
                  }
                </div>
                <div class="flex items-center text-[10px] font-black text-gray-400 uppercase tracking-tighter mt-1 pt-2 border-t border-gray-200/60">
                  <span class="w-6 opacity-50 text-sm">📅</span> Joined ${joinDate}
                </div>
              </div>
            </div>`;
          })
          .join("");
      }

      function formatDate(dateString) {
        return new Date(dateString).toLocaleDateString("en-IN", {
          day: "2-digit",
          month: "short",
          year: "numeric",
        });
      }

      function renderPagination(total, current) {
        const controls = document.getElementById("pagination-controls");
        const info = document.getElementById("pagination-info");

        info.innerText = `Page ${current} of ${total}`;
        controls.innerHTML = "";

        if (total <= 1) return;

        // Prev Button
        if (current > 1) {
          controls.innerHTML += `<button onclick="changePage(${
            current - 1
          })" class="px-4 py-2 rounded-xl bg-white border border-gray-200 text-gray-600 active:bg-gray-100 transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg></button>`;
        }

        // Number Buttons
        for (let i = 1; i <= total; i++) {
          if (
            i === 1 ||
            i === total ||
            (i >= current - 1 && i <= current + 1)
          ) {
            controls.innerHTML += `
              <button onclick="changePage(${i})" 
                class="w-10 h-10 rounded-xl font-black text-xs transition-all 
                ${
                  i === current
                    ? "bg-gray-900 text-white shadow-lg"
                    : "bg-white border border-gray-100 text-gray-400"
                }">
                ${i}
              </button>`;
          }
        }

        // Next Button
        if (current < total) {
          controls.innerHTML += `<button onclick="changePage(${
            current + 1
          })" class="px-4 py-2 rounded-xl bg-white border border-gray-200 text-gray-600 active:bg-gray-100 transition-all"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></button>`;
        }
      }

      function changePage(p) {
        state.page = p;
        window.scrollTo({ top: 0, behavior: "smooth" });
        loadUsers();
      }

      document.addEventListener("DOMContentLoaded", loadUsers);
    </script>
    <%- include('../partials/footer') %>
  </body>
</html>
