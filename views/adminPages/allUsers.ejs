<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Member Directory | FullStack Café</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body class="bg-gray-50 antialiased font-sans">
    <%- include('../partials/header') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-12">
      <div
        class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8 md:mb-12"
      >
        <div>
          <h1
            class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight"
          >
            Member Directory
          </h1>
          <p class="text-gray-500 font-medium mt-2 text-sm md:text-base">
            Manage all registered students and administrative staff.
          </p>
        </div>
        <div
          class="bg-white px-6 py-4 md:py-3 rounded-2xl border border-gray-100 shadow-sm flex flex-row md:flex-col items-center md:items-start justify-between md:justify-center gap-2"
        >
          <span
            class="text-[10px] font-black uppercase tracking-widest text-gray-400 block"
            >Total Registry</span
          >
          <span class="text-xl md:text-2xl font-black text-red-700">
            <%= allUsers.length %> Users
          </span>
        </div>
      </div>

      <div
        class="bg-white md:rounded-xl shadow-sm border border-gray-100 overflow-hidden -mx-4 md:mx-0"
      >
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-gray-50/50 border-b border-gray-100">
                <th
                  class="p-6 text-[10px] font-black uppercase tracking-widest text-gray-400"
                >
                  User Profile
                </th>
                <th
                  class="p-6 text-[10px] font-black uppercase tracking-widest text-gray-400"
                >
                  Contact Details
                </th>
                <th
                  class="p-6 text-[10px] font-black uppercase tracking-widest text-gray-400"
                >
                  Permissions
                </th>
                <th
                  class="p-6 text-[10px] font-black uppercase tracking-widest text-gray-400"
                >
                  Join Date
                </th>
                <th
                  class="p-6 text-[10px] font-black uppercase tracking-widest text-gray-400 text-right"
                >
                  Actions
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% if (allUsers && allUsers.length > 0) { %> <%
              allUsers.forEach(function(u) { %>
              <tr class="group hover:bg-gray-50/50 transition-colors">
                <td class="p-6">
                  <div class="flex items-center gap-4">
                    <img
                      src="/avatars/<%= u.avatar || 'default-avatar.png' %>"
                      class="w-12 h-12 rounded-full object-cover"
                      onerror="this.src='https://ui-avatars.com/api/?name=User'"
                    />
                    <div>
                      <span class="block font-black text-gray-900"
                        ><%= u.username %></span
                      >
                      <span class="text-[10px] text-gray-400 uppercase"
                        >ID: <%= u._id.toString().slice(-6) %></span
                      >
                    </div>
                  </div>
                </td>
                <td class="p-6">
                  <div class="flex flex-col gap-2 min-w-[180px]">
                    <div
                      class="flex items-center gap-2 px-3 py-1.5 rounded-xl bg-gray-50 border border-gray-100"
                    >
                      <span
                        class="text-[9px] font-black uppercase tracking-tighter text-gray-400"
                        >Phone</span
                      >
                      <span class="text-[11px] font-bold text-gray-700"
                        ><%= u.phone || 'N/A' %></span
                      >
                    </div>
                    <div
                      class="flex items-center gap-2 px-3 py-1.5 rounded-xl bg-gray-50 border border-gray-100 group-hover:border-green-200 transition-colors"
                    >
                      <span
                        class="text-[9px] font-black uppercase tracking-tighter text-gray-400"
                        >Email</span
                      >
                      <span
                        class="text-[11px] font-bold text-gray-700 truncate max-w-[150px]"
                        title="<%= u.email %>"
                        ><%= u.email %></span
                      >
                    </div>
                  </div>
                </td>
                <td class="p-6">
                  <span
                    class="px-3 py-1 rounded-xl text-[10px] font-black uppercase tracking-widest <%= u.role === 'admin' ? 'bg-green-100 text-green-700 border border-green-200' : 'bg-gray-100 text-gray-600 border border-gray-200' %>"
                  >
                    <%= u.role %>
                  </span>
                </td>
                <td class="p-6 text-sm text-gray-500">
                  <%= new Date(u.createdAt).toDateString() %>
                </td>
                <td class="p-6 text-right">
                  <a
                    href="https://mail.google.com/mail/?view=cm&fs=1&to=<%= u.email %>"
                    target="_blank"
                    class="inline-flex items-center gap-2 bg-red-50 text-red-700 px-4 py-2 rounded-xl font-bold text-xs hover:bg-red-700 hover:text-white transition-all shadow-sm"
                  >
                    Gmail
                  </a>
                </td>
              </tr>
              <% }) %> <% } %>
            </tbody>
          </table>
        </div>

        <div class="md:hidden divide-y divide-gray-100">
          <% if (allUsers && allUsers.length > 0) { %> <%
          allUsers.forEach(function(u) { %>
          <div class="p-5 flex flex-col gap-4">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <img
                  src="/avatars/<%= u.avatar || 'default-avatar.png' %>"
                  class="w-10 h-10 rounded-full object-cover border border-gray-100"
                  onerror="this.src='https://ui-avatars.com/api/?name=User'"
                />
                <div>
                  <span class="block font-black text-gray-900"
                    ><%= u.username %></span
                  >
                  <span
                    class="text-[9px] text-gray-400 uppercase tracking-wider"
                    >ID: <%= u._id.toString().slice(-6) %></span
                  >
                </div>
              </div>
              <span
                class="px-2.5 py-1 rounded-lg text-[9px] font-black uppercase tracking-widest <%= u.role === 'admin' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>"
              >
                <%= u.role %>
              </span>
            </div>

            <div class="grid grid-cols-2 gap-2">
              <div class="bg-gray-50 p-3 rounded-xl border border-gray-100">
                <span
                  class="text-[8px] font-black uppercase text-gray-400 block mb-0.5"
                  >Phone</span
                >
                <span class="text-[11px] font-bold text-gray-700 block"
                  ><%= u.phone || 'N/A' %></span
                >
              </div>
              <div class="bg-gray-50 p-3 rounded-xl border border-gray-100">
                <span
                  class="text-[8px] font-black uppercase text-gray-400 block mb-0.5"
                  >Joined</span
                >
                <span class="text-[10px] font-bold text-gray-700 block"
                  ><%= new Date(u.createdAt).toLocaleDateString() %></span
                >
              </div>
            </div>

            <div class="flex items-center gap-2">
              <a
                href="https://mail.google.com/mail/?view=cm&fs=1&to=<%= u.email %>"
                target="_blank"
                class="flex-1 flex items-center justify-center gap-2 bg-red-700 text-white py-3 rounded-xl font-bold text-xs active:scale-95 transition-all"
              >
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                  <path
                    d="M24 4.5v15c0 .85-.65 1.5-1.5 1.5H21V7.38l-9 5.65-9-5.65V21H1.5c-.85 0-1.5-.65-1.5-1.5v-15c0-.4.15-.75.45-1.05.3-.3.65-.45 1.05-.45H3.6l8.4 5.25 8.4-5.25h2.1c.4 0 .75.15 1.05.45.3.3.45.65.45 1.05z"
                  />
                </svg>
                Contact via Gmail
              </a>
            </div>
          </div>
          <% }) %> <% } else { %>
          <div class="p-10 text-center text-gray-400 font-bold">
            No users found.
          </div>
          <% } %>
        </div>
      </div>
    </main>

    <%- include('../partials/footer') %>
  </body>
</html>
