<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Join the Community | FullStack Café</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes slideUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-slide-up {
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .success-pulse {
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0% {
          box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.4);
        }
        70% {
          box-shadow: 0 0 0 10px rgba(22, 163, 74, 0);
        }
        100% {
          box-shadow: 0 0 0 0 rgba(22, 163, 74, 0);
        }
      }
    </style>
  </head>
  <body class="bg-gray-50 antialiased font-sans flex flex-col min-h-screen">
    <%- include('partials/header') %>

    <main
      class="flex-grow flex items-center justify-center py-10 md:py-16 px-4"
    >
      <div
        class="bg-white p-8 md:p-10 rounded-[2.5rem] shadow-xl shadow-gray-200/50 w-full max-w-[440px] border border-gray-100 animate-slide-up"
      >
        <div class="text-center mb-8">
          <div
            class="inline-flex items-center justify-center w-14 h-14 bg-red-50 rounded-2xl mb-4"
          >
            <span class="text-2xl">🍕</span>
          </div>
          <h2
            class="text-3xl font-black text-gray-900 tracking-tighter mb-2 italic"
          >
            Join <span class="text-red-700">CampusEats.</span>
          </h2>
          <p class="text-gray-500 font-medium text-sm">
            Create your account to start ordering.
          </p>
        </div>

        <form id="signupForm" class="space-y-4">
          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1"
              >Full Name</label
            >
            <input
              type="text"
              name="username"
              autocomplete="name"
              class="w-full px-5 py-4 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-700 outline-none transition bg-gray-50/50 font-bold text-gray-900"
              placeholder="John Doe"
              required
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label
                class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1"
                >Email</label
              >
              <input
                type="email"
                name="email"
                autocomplete="email"
                inputmode="email"
                class="w-full px-5 py-4 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-700 outline-none transition bg-gray-50/50 font-bold text-gray-900"
                placeholder="doe@cqst.in"
                required
              />
            </div>
            <div>
              <label
                class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1"
                >Phone</label
              >
              <input
                type="tel"
                name="phone"
                autocomplete="tel"
                inputmode="tel"
                class="w-full px-5 py-4 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-700 outline-none transition bg-gray-50/50 font-bold text-gray-900"
                placeholder="98765..."
                required
              />
            </div>
          </div>

          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1"
              >Password</label
            >
            <input
              type="password"
              name="password"
              autocomplete="new-password"
              class="w-full px-5 py-4 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-700 outline-none transition bg-gray-50/50 font-bold text-gray-900"
              placeholder="••••••••"
              required
            />
          </div>

          <div>
            <label
              class="block text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-2 ml-1"
              >Profile Picture</label
            >
            <label
              for="file-upload"
              class="group flex flex-col items-center justify-center w-full py-6 border-2 border-dashed border-gray-200 rounded-2xl cursor-pointer hover:bg-red-50 hover:border-red-200 transition bg-gray-50/30"
            >
              <div
                class="flex flex-col items-center justify-center text-center px-4"
              >
                <div
                  id="upload-preview"
                  class="mb-2 transition-transform group-hover:scale-110"
                >
                  <svg
                    id="upload-icon"
                    class="w-8 h-8 text-gray-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M12 4v16m8-8H4"
                      stroke-width="2.5"
                      stroke-linecap="round"
                    />
                  </svg>
                </div>
                <p
                  id="file-name"
                  class="text-[10px] font-black text-gray-500 uppercase tracking-widest"
                >
                  Tap to upload photo
                </p>
              </div>
              <input
                id="file-upload"
                name="avatar"
                type="file"
                class="hidden"
                onchange="handleFile(this)"
                accept="image/*"
              />
            </label>
          </div>

          <div
            id="errorBox"
            class="hidden bg-red-50 border border-red-100 text-red-700 px-4 py-4 rounded-2xl text-[11px] font-black uppercase tracking-wide text-center"
          ></div>

          <button
            type="submit"
            id="signupBtn"
            class="w-full bg-gray-900 text-white py-5 rounded-2xl font-black text-xs uppercase tracking-[0.2em] hover:bg-red-700 shadow-xl shadow-gray-200 transition-all duration-300 active:scale-[0.97]"
          >
            Launch Account
          </button>
        </form>

        <p
          class="mt-8 text-center text-xs font-bold text-gray-400 uppercase tracking-widest"
        >
          Already a member?
          <a
            href="/login"
            class="text-red-700 hover:underline underline-offset-4 ml-1"
            >Login here</a
          >
        </p>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script>
      function handleFile(input) {
        const nameDisplay = document.getElementById("file-name");
        const iconContainer = document.getElementById("upload-preview");

        if (input.files && input.files[0]) {
          const fileName = input.files[0].name;
          nameDisplay.innerText =
            fileName.length > 20 ? fileName.substring(0, 17) + "..." : fileName;
          nameDisplay.classList.add("text-red-700");
          // Change icon to a checkmark
          iconContainer.innerHTML = `<svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>`;
        }
      }

      document
        .getElementById("signupForm")
        .addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = document.getElementById("signupBtn");
          const errorBox = document.getElementById("errorBox");
          const formData = new FormData(e.target);

          btn.disabled = true;
          btn.innerHTML = `COOKING YOUR ACCOUNT...`;
          errorBox.classList.add("hidden");

          try {
            const response = await fetch("/signup", {
              method: "POST",
              body: formData,
            });

            const data = await response.json();

            if (data.success) {
              btn.classList.replace("bg-gray-900", "bg-green-600");
              btn.classList.add("success-pulse");
              btn.innerText = "WELCOME TO THE CLUB! 🎉";
              setTimeout(() => {
                window.location.href = "/login?signup=success";
              }, 1500);
            } else {
              errorBox.innerText = data.message;
              errorBox.classList.remove("hidden");
              btn.disabled = false;
              btn.innerText = "LAUNCH ACCOUNT";
            }
          } catch (err) {
            errorBox.innerText = "NETWORK ERROR.";
            errorBox.classList.remove("hidden");
            btn.disabled = false;
            btn.innerText = "LAUNCH ACCOUNT";
          }
        });
    </script>
  </body>
</html>
